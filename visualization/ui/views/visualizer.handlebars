<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <title>Visualizer</title>
  <data id="static-visualization" value={{static}}></data>
  <script type="module" src="src/visualizer.js" charset="utf-8" defer></script>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"> </script>
</head>

<body id="body">
  <div id="wrapper" class={{role}}>
    <div id="help-window" hidden>
      <button id="close-help-window-button">X</button>
      <iframe height="90%" width="90%" src="/help.html"></iframe>
    </div>
    <div id="zoom-container" hidden>
      <button id="zoom-in" class="file-icon" title="Zoom In">
        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      </button>
      <button id="zoom-out" class="file-icon" title="Zoom Out">
       <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      </button>
    </div>
    <button id="editor-button" hidden>editor mode</button>
    <button id="participant-button" hidden>participant mode</button>
    <div id="uploader-container" hidden>
      <input type="file" id="svg-uploader" accept=".svg, .jpg, .jpeg, .png, .JPG, .JPEG, .PNG, image/jpeg, image/png, image/svg+xml" style="margin: 10px;" />
    </div>

    <div id="file-toolbar" hidden>
      <button class="file-icon" id="icon-save" title="Save">
        <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
          <polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline>
        </svg>
      </button>
      <button class="file-icon" id="icon-import" title="Import">
        <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5"/>
        </svg>
      </button>
      <button class="file-icon" id="icon-export" title="Export">
        <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 8l-5-5-5 5M12 4.2v10.3"/>
        </svg>
      </button>
    </div>
    
    <div id="button-header" hidden>
      <small id="save-status"></small>

      <div id="upload-progress-container" hidden>
        <div id="upload-progress-bar">
          <div id="upload-progress-fill"></div>
        </div>
        <small id="upload-progress-text"></small>
      </div>

      <div class="file dropdown" hidden>
        File
        <div class="dropdown-buttons file-buttons">
        </div>
      </div>

      <div id="options-dropdown" class="options dropdown" hidden>
        Options
        <div class="dropdown-buttons option-buttons">
        </div>
      </div>

      <div class="tools dropdown" hidden>
        Tools
        <div class="dropdown-buttons tool-buttons">
        </div>
      </div>

      <button id="help-button" hidden>?</button>

    </div>

    <div id="drop-zone-overlay" hidden>
      <div class="drop-zone-card">
        <p>Drop image here</p>
        <small>.svg, .png, .jpg</small>
      </div>
    </div>

    <div id="visual-container" data-svg-loaded="{{#if svg}}true{{else}}false{{/if}}">
      {{#if svg}}
      {{{svg}}}
      {{else}}
      <div id="svg-loading-spinner">
        <div class="spinner"></div>
        <p>Loading visualization...</p>
      </div>
      {{/if}}
    </div>
    
    <div id="tooltip-container" class="card" hidden>
      <div class="card-body">
        <div id="tooltip-setting" class="form-check" hidden>
          <input class="form-check-input" type="checkbox" value="" id="checkTooltip">
          <label class="form-check-label" for="checkTooltip">
            Details on Hover?
          </label>
        </div>
        <p id="tooltip-detail" class="card-text" style="margin-bottom: 0rem">No Information</p>
        <div class="input-group mb-3" id="groupTooltip" style="margin-top: 0.5rem" hidden>
          <input class="form-control" type="text" placeholder="Edit Label" id="controlTooltip">
          <button id="modifyButton" class="btn btn-outline-primary" type="button">
            Edit
          </button>
        </div>
      </div>
    </div>
  </div>

</body>

</html>